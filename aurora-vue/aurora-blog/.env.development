# =============================================================================
# aurora-blog 前端环境配置
# 部署时只需修改此文件中的 VUE_APP_* 变量即可切换所有外部服务地址
# =============================================================================

# ---------------------------------------------------------------------------
# 对象存储 (OSS / MinIO) 基础 URL
# 用于存放文章封面、头像、配置图片等静态资源文件
# 开发环境: 使用本地 MinIO 服务
# 生产环境: 替换为你的云存储域名（如阿里云 OSS / 腾讯云 COS）
# 注意: 末尾不要带斜杠
# ---------------------------------------------------------------------------
VUE_APP_OSS_URL=http://localhost:9000/aurora

# ---------------------------------------------------------------------------
# 博客网站自身域名
# 用于 QQ 登录回调、邮件模板链接等
# 开发环境: 使用本地后端地址
# 生产环境: 替换为你的实际博客域名（如 https://www.yourdomain.com）
# ---------------------------------------------------------------------------
VUE_APP_BLOG_URL=http://localhost:8080

# ---------------------------------------------------------------------------
# QQ 互联 APP ID
# 开发环境可以为空，生产环境填入你在 QQ 互联申请的 APP ID
# ---------------------------------------------------------------------------
VUE_APP_QQ_APP_ID=

# ---------------------------------------------------------------------------
# QQ 登录回调地址
# 需要用户授权后跳转回你的网站，必须与 QQ 互联后台配置的回调地址一致
# 开发环境: http://localhost:8080/oauth/login/qq
# 生产环境: 替换为 https://www.yourdomain.com/oauth/login/qq
# ---------------------------------------------------------------------------
VUE_APP_QQ_REDIRECT_URI=http://localhost:8080/oauth/login/qq

# ---------------------------------------------------------------------------
# 公安备案图标 URL（页脚的 icon）
# 通常与 OSS_URL 一致，也可以单独指定
# ---------------------------------------------------------------------------
VUE_APP_GONGAN_ICON_URL=http://localhost:9000/aurora/config/gongan-beian-icon.png
