# =============================================================================
# aurora-admin 前端环境配置 — 生产环境
# 部署前请将所有 VUE_APP_* 地址替换为你自己的服务地址
# =============================================================================

# 对象存储 URL — 替换为你购买云服务器后的 OSS 域名
VUE_APP_OSS_URL=https://static.yourdomain.com/aurora

# 博客网站域名 — 替换为你的实际域名
VUE_APP_BLOG_URL=https://www.yourdomain.com
