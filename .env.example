# Aurora Blog - 环境变量配置参考
# ==============================
#
# 复制本文件为 .env 并填入实际值即可配置后端运行环境。
# 开发环境可直接使用 application-dev.yml 的默认值开箱即用。
# 生产环境必须设置以下所有变量，否则启动会失败。

# ─── 服务器 ──────────────────────────────────────────
# SERVER_PORT=8080

# ─── MySQL 数据库 ────────────────────────────────────
# 开发环境默认: jdbc:mysql://localhost:3306/aurora?serverTimezone=Asia/Shanghai&allowMultiQueries=true&useUnicode=true&characterEncoding=utf8&useSSL=false
# MYSQL_URL=jdbc:mysql://localhost:3306/aurora?serverTimezone=Asia/Shanghai&allowMultiQueries=true
# MYSQL_USERNAME=aurora
# MYSQL_PASSWORD=aurora123

# ─── Redis ───────────────────────────────────────────
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=aurora123

# ─── RabbitMQ ────────────────────────────────────────
# RABBITMQ_HOST=localhost
# RABBITMQ_PORT=5672
# RABBITMQ_USERNAME=aurora
# RABBITMQ_PASSWORD=aurora123

# ─── Elasticsearch ───────────────────────────────────
# 开发环境默认: http://localhost:9201 (本机 9200 被占用时映射)
# ES_URIS=http://localhost:9200
# ES_USERNAME=
# ES_PASSWORD=

# ─── 邮件（SMTP） ────────────────────────────────────
# MAIL_HOST=smtp.163.com
# MAIL_PORT=465
# MAIL_USERNAME=your-email@163.com
# MAIL_PASSWORD=your-smtp-password

# ─── JWT ─────────────────────────────────────────────
# 生产环境务必使用 256 位随机密钥！
# JWT_SECRET=aurora-dev-jwt-secret-key-change-in-production

# ─── 搜索模式 ────────────────────────────────────────
# mysql: 使用 MySQL LIKE 查询（dev 默认）
# elasticsearch: 使用 ES 全文检索（prod 默认）
# SEARCH_MODE=mysql

# ─── 文件上传 ────────────────────────────────────────
# UPLOAD_MODE=minio     # minio 或 oss
# ── MinIO ──
# MINIO_URL=http://localhost:9000
# MINIO_ENDPOINT=http://localhost:9000
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin
# MINIO_BUCKET=aurora
# ── 阿里云 OSS ──
# OSS_URL=http://Bucket域名/
# OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
# OSS_ACCESS_KEY_ID=your-access-key-id
# OSS_ACCESS_KEY_SECRET=your-access-key-secret
# OSS_BUCKET_NAME=your-bucket-name

# ─── 网站 ────────────────────────────────────────────
# WEBSITE_URL=http://localhost:8080

# ─── QQ 登录 ────────────────────────────────────────
# QQ_APP_ID=your-qq-app-id
# （以下 URL 通常无需修改）
# QQ_CHECK_TOKEN_URL=https://graph.qq.com/oauth2.0/me?access_token={access_token}
# QQ_USER_INFO_URL=https://graph.qq.com/user/get_user_info?openid={openid}&access_token={access_token}&oauth_consumer_key={oauth_consumer_key}
