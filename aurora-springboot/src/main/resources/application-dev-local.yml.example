# ============================================================
# 本地开发配置覆盖模板
# ============================================================
# 使用方法:
#   1. 复制本文件为 application-dev-local.yml
#   2. 修改需要的配置项（端口、密码等）
#   3. 重启后端，配置自动生效
#
# 本文件列在 .gitignore 中，不会被提交到版本库。
# 所有设置会覆盖 application-dev.yml 中的对应值。
# ============================================================

server:
  port: 8080

spring:
  datasource:
    url: jdbc:mysql://localhost:3306/aurora?serverTimezone=Asia/Shanghai&allowMultiQueries=true&useUnicode=true&characterEncoding=utf8&useSSL=false
    username: aurora
    password: aurora123
  data:
    redis:
      host: localhost
      port: 6379
      password: aurora123
  rabbitmq:
    host: localhost
    port: 5672
    username: aurora
    password: aurora123
  elasticsearch:
    uris: http://localhost:9201
  mail:
    host: smtp.163.com
    port: 465
    username: ''      # 替换为实际邮箱
    password: ''      # 替换为 SMTP 密码

upload:
  mode: minio
  minio:
    url: http://localhost:9000
    endpoint: http://localhost:9000
    access-key: minioadmin
    secret-key: minioadmin
    bucket-name: aurora

jwt:
  secret: aurora-dev-jwt-secret-key-change-in-production

search:
  mode: mysql
